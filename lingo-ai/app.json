{
  "expo": {
    "name": "Lingo AI",
    "slug": "lingo-ai",
    "version": "1.0.0",
    "scheme": "lingo-ai",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lingoai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lingo AI needs microphone access to transcribe speech in real time."
      }
    },
    "android": {
      "package": "com.lingoai.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F14",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "expo-secure-store",
        { "faceIDPermission": "Lingo AI uses Face ID to secure your API keys." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
